		add(returnB,layC);
		
		catA.setText(Catalogue.viewCat());
        
        // Row 1
		layC.insets = new Insets(10,5,5,5);
        layC.gridx=3; layC.gridy=0; add(nameL,layC);
        layC.gridx=4; add(nameField,layC);
        
        // Row 2
		layC.insets = new Insets(5,5,5,5);
        layC.gridx=3; layC.gridy=1; add(passL,layC);
        layC.gridx=4; add(passwordField,layC);
        
