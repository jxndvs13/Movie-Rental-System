	public void stateChanged(ChangeEvent event) {
		update();
	}
	
	public void actionPerformed(ActionEvent event) {
		if (event.getSource() == rentB) {
			int movid = (Integer) searchS.getValue();
			if (movid != 0 && UserDB.getCredit() >= Catalogue.getPrice(movid) && UserDB.getRentId() == 0) {
				Catalogue.reduceStock(movid);
				UserDB.setRented(movid);
				UserDB.takeCredit(Catalogue.getPrice(movid));
				UserDB.addHistory(movid);
			}
		}
		else if (event.getSource() == returnB) {
			if (UserDB.getRentId() != 0) {
				Catalogue.increaseStock(UserDB.getRentId());
				UserDB.setRented(0);
			}
		}
		if (event.getSource() == createBtn) { // should need just three for here
            //UserDB.createUser(name, pass); // I can just connect to UserDB for this part to make it smaller
            // Do this with all of the options!!!
            outputArea.append("User created!\n");
        }

        else if (event.getSource() == loginBtn) {
           outputArea.append(UserDB.login(nameField.getText(),passwordField.getText()));
           update();
        }

        else if (event.getSource() == changeNameBtn) {
            //UserDB.changeName(name, name); // id and name to change
            outputArea.append("Name changed.\n");
        }

        else if (event.getSource() == changePassBtn) {
            //UserDB.changePassword(id, pass); //need an id and new password
            outputArea.append("Password changed.\n");
        }

        else if (event.getSource() == addCreditBtn) {
        	outputArea.append(UserDB.addCredit(Double.parseDouble(depositField.getText())) + "\n");
        	depositField.setText("");
        }

        else if (event.getSource() == addHistoryBtn) {
            String record = historyArea.getText();
            //UserDB.addHistory(id, record); //record
            outputArea.append("History added.\n");
        }
		
		update();
	}
	
	public void update() {
		creditField.setText(UserDB.getCredit().toString());
		rentedArea.setText(UserDB.getRented());
        historyArea.setText(UserDB.getHistory());
		catA.setText(Catalogue.viewCat());
		if ((Integer) searchS.getValue() == 0) {
			selectA.setText("");
		}
		else {
			selectA.setText(Catalogue.displayMov((Integer) searchS.getValue()));
		}
	}
	
	public static void main(String[] args) {
		SystemFrame frame = new SystemFrame();
		frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		frame.pack();
		frame.setVisible(true);
	}
}
