package movie_rental_system;

import java.awt.*;
import java.awt.event.*;
import javax.swing.*;
import javax.swing.event.*;

public class SystemFrame extends JFrame implements ActionListener, ChangeListener {
	private JTextArea catA;
	private JTextArea selectA;
	private JSpinner searchS;
	private JButton rentB;
	private JButton returnB;
	
	//text fields, and areas
    private JTextField nameField, passwordField, creditField, depositField;
    private JTextArea historyArea, outputArea, rentedArea;
    // buttons, use Btn-shorter
    private JButton createBtn, loginBtn, changeNameBtn, changePassBtn;
    private JButton addCreditBtn;
	
	SystemFrame() {
		JLabel catL = new JLabel("Full Catalogue");
		JLabel idL = new JLabel("Enter ID:");
		JLabel selectL = new JLabel("Selected Film");
        JLabel nameL = new JLabel("Username:"); //name
        JLabel passL = new JLabel("Password:"); //pass
        JLabel creditL = new JLabel("Credit:"); //credit
        JLabel depositL = new JLabel("Deposit:");
        JLabel rentedL = new JLabel("Currently Rented:");
        JLabel historyL = new JLabel("History:"); //history
        
        // Fields
        nameField = new JTextField(10);
        passwordField = new JTextField(10);
        creditField = new JTextField(10);
        creditField.setEditable(false);
        depositField = new JTextField(10);
        historyArea = new JTextArea(2, 15);
		historyArea.setEditable(false);
        rentedArea = new JTextArea(2, 10);
		rentedArea.setEditable(false);

        // I should have an output area
        outputArea = new JTextArea(4, 20);
        outputArea.setEditable(false);
        JScrollPane scrollPane = new JScrollPane(outputArea);

        // Buttons
        createBtn = new JButton("Create User");
        loginBtn = new JButton("Login");
        changeNameBtn = new JButton("Change Name");
        changePassBtn = new JButton("Change Password");
        addCreditBtn = new JButton("Add Credit");
        
        // my buttons
        JButton[] buttons = {createBtn, loginBtn, changeNameBtn, changePassBtn,
                             addCreditBtn};
        
        for (JButton b : buttons) {
            b.addActionListener(this); //actions
        }
		
		catA = new JTextArea(10,20); //height, width
		JScrollPane scrollP = new JScrollPane(catA);
		catA.setEditable(false);
		
		selectA = new JTextArea(2,20);
		selectA.setEditable(false);
		
		SpinnerNumberModel idM = new SpinnerNumberModel(0, 0, 4, 1); //init, min, max, step
		searchS = new JSpinner(idM);
		searchS.addChangeListener(this);
		
		rentB = new JButton("Rent");
		rentB.addActionListener(this);
		
		returnB = new JButton("Return");
		returnB.addActionListener(this);
		
		setLayout(new GridBagLayout());
		GridBagConstraints layC = new GridBagConstraints();
		layC.insets = new Insets(10,5,0,5); //top, left, bottom, right
		layC.gridx = 0;
		layC.gridy = 0;
		add(catL, layC);
		
		layC.gridx = 1;
		layC.gridwidth = 2;
		add(selectL, layC);

		layC.insets = new Insets(5,10,10,10);
		layC.gridx = 0;
		layC.gridy = 1;
		layC.gridwidth = 1;
		layC.gridheight = 8;
		layC.fill = GridBagConstraints.BOTH;
		layC.weightx = 1.0;
		layC.weighty = 1.0;
		add(scrollP, layC);

		layC.insets = new Insets(5,5,5,5);
		layC.gridx = 1;
		layC.gridheight = 2;
		layC.gridwidth = 2;
		layC.weightx = 0;
		layC.weighty = 0;
		layC.fill = GridBagConstraints.NONE;
		add(selectA, layC);
		
		layC.gridy = 3;
		layC.gridheight = 1; layC.gridwidth = 1;
		add(idL, layC);
		
		layC.gridx = 2;
		add(searchS, layC);
		
		layC.gridx = 1;
		layC.gridy = 4;
		layC.fill = GridBagConstraints.BOTH;
		add(rentB,layC);
		
		layC.gridx = 2;
		add(returnB,layC);
		
		catA.setText(Catalogue.viewCat());
        
        // Row 1
		layC.gridy=0; layC.insets = new Insets(10,5,5,5);
        layC.gridx=3; add(nameL,layC);
        layC.gridx=4; add(nameField,layC);
        layC.gridx=5; add(createBtn,layC);
        
        // Row 2
        layC.gridy=1; layC.insets = new Insets(5,5,5,5);
        layC.gridx=3; add(passL,layC);
        layC.gridx=4; add(passwordField,layC);
        layC.gridx=5; add(loginBtn,layC);
        
        // Row 3
        layC.gridy=2; layC.gridheight=2;
        layC.gridx=3; add(creditL,layC);
        layC.gridx=4; add(creditField,layC);
        layC.gridx=5; add(changeNameBtn,layC);
        
        // Row 4
        layC.gridy=4; layC.gridheight=1;
        layC.gridx=3; add(depositL,layC);
        layC.gridx=4; add(depositField,layC);
        layC.gridx=5; add(changePassBtn,layC);
        
        // Row 5
        layC.gridy=5;
        layC.gridx=3; add(historyL,layC);
        layC.gridx=5; add(addCreditBtn,layC);
        layC.gridx=4; layC.gridheight=4; layC.insets = new Insets(5,5,10,5);
		add(historyArea,layC);
        
        //Rented
        layC.gridy=5; layC.gridheight=1; layC.insets = new Insets(5,5,5,5);
        layC.gridx=1; add(rentedL,layC);
        layC.gridy=6; layC.gridwidth=2;
        add(rentedArea,layC);
        
        // Output
        layC.gridx=1; layC.gridy=7; layC.gridheight=2; layC.gridwidth=3;
        layC.insets = new Insets(5,5,10,5);
		add(scrollPane,layC);
	}
	
	public void stateChanged(ChangeEvent event) {
		update();
	}
	
	public void actionPerformed(ActionEvent event) {
		//Rent Movie
		if (event.getSource() == rentB) {
			int movid = (Integer) searchS.getValue();
			if (movid == 0) {
				outputArea.append("Please Select a Film\n");
			}
			else {
				if (UserDB.getRentId() != 0) {
					outputArea.append("Please Return your Rented Film\n");
				}
				else if (UserDB.getCredit() < Catalogue.getPrice(movid)) {
					outputArea.append("Please Deposit More Credit\n");
				}
				else {
					Catalogue.reduceStock(movid);
					outputArea.append(UserDB.setRented(movid));
					UserDB.takeCredit(Catalogue.getPrice(movid));
					UserDB.addHistory(movid);
				}
			}
		}
		
		//Return Movie
		else if (event.getSource() == returnB) {
			if (UserDB.getRentId() != 0) {
				Catalogue.increaseStock(UserDB.getRentId());
				UserDB.setRented(0);
			}
		}
		
		//Create User
		else if (event.getSource() == createBtn) {
            outputArea.append(UserDB.createUser(nameField.getText(),passwordField.getText()));
            outputArea.append(UserDB.login(nameField.getText(),passwordField.getText()));
            passwordField.setText("");
        }

        //Login as User
		else if (event.getSource() == loginBtn) {
           outputArea.append(UserDB.login(nameField.getText(),passwordField.getText()));
           passwordField.setText("");
        }

        //Change Username
		else if (event.getSource() == changeNameBtn) {
            outputArea.append(UserDB.changeName(nameField.getText()));
        }

		//Change Password
        else if (event.getSource() == changePassBtn) {
            outputArea.append(UserDB.changePassword(passwordField.getText()));
        }

		//Add Credit
        else if (event.getSource() == addCreditBtn) {
        	outputArea.append(UserDB.addCredit(Double.parseDouble(depositField.getText())));
        	depositField.setText("");
        }
		
		update();
	}
	
	public void update() {
		creditField.setText(UserDB.getCredit().toString());
		rentedArea.setText(UserDB.getRented());
        historyArea.setText(UserDB.getHistory());
		catA.setText(Catalogue.viewCat());
		if ((Integer) searchS.getValue() == 0) {
			selectA.setText("");
		}
		else {
			selectA.setText(Catalogue.displayMov((Integer) searchS.getValue()));
		}
	}
	
	public static void main(String[] args) {
		SystemFrame frame = new SystemFrame();
		frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		frame.pack();
		frame.setVisible(true);
	}
}
